<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Property Queue</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            padding: 0;
        }
        header {
            background-color: #2c3e50;
            color: white;
            padding: 15px;
            text-align: center;
        }
        main {
            max-width: 900px;
            margin: auto;
            padding: 20px;
        }
        .property-card {
            background: white;
            border-radius: 5px;
            padding: 15px;
            margin-bottom: 15px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        .property-card h3 {
            margin: 0 0 10px;
        }
        .property-card p {
            margin: 5px 0;
        }
        button {
            background-color: #27ae60;
            color: white;
            border: none;
            padding: 8px 12px;
            cursor: pointer;
            border-radius: 3px;
        }
        button:hover {
            background-color: #219150;
        }
    </style>
</head>
<body>

<header>
    <h1>Property Queue</h1>
</header>

<main id="property-list">
    <!-- Properties will be loaded here -->
</main>

<script>
    // Example property queue data
    const propertyQueue = [
        { id: 1, name: "Green Villa", location: "Downtown", price: "$250,000" },
        { id: 2, name: "Ocean View Apartment", location: "Beachside", price: "$450,000" },
        { id: 3, name: "Mountain Cabin", location: "Highlands", price: "$150,000" }
    ];

    const propertyList = document.getElementById('property-list');

    // Render properties
    function renderQueue() {
        propertyList.innerHTML = '';
        propertyQueue.forEach(property => {
            const card = document.createElement('div');
            card.className = 'property-card';
            card.innerHTML = `
                <h3>${property.name}</h3>
                <p><strong>Location:</strong> ${property.location}</p>
                <p><strong>Price:</strong> ${property.price}</p>
                <button onclick="removeFromQueue(${property.id})">Remove</button>
            `;
            propertyList.appendChild(card);
        });
    }

    // Remove property from queue
    function removeFromQueue(id) {
        const index = propertyQueue.findIndex(p => p.id === id);
        if (index !== -1) {
            propertyQueue.splice(index, 1);
            renderQueue();
        }
    }

    // Initial render
    renderQueue();
</script>

</body>
</html>
